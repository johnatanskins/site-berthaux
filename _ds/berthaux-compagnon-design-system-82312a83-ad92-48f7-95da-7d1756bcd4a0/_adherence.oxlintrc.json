{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BadgePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|onDark|style|key|ref|className|style|children)$/]",
        "message": "<BadgePill> doesn't accept that prop. Declared props: children, tone, icon, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BadgePill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:star|gold|none)$/]",
        "message": "<BadgePill> tone must be one of 'star' | 'gold' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|icon|iconRight|type|onClick|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, icon, iconRight, type, onClick, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:red|navy|ghost|outlineWhite)$/]",
        "message": "<Button> variant must be one of 'red' | 'navy' | 'ghost' | 'outlineWhite'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Button> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommuneChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|style|key|ref|className|style|children)$/]",
        "message": "<CommuneChip> doesn't accept that prop. Declared props: children, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|href|tone|big|style|key|ref|className|style|children)$/]",
        "message": "<ContactItem> doesn't accept that prop. Declared props: icon, label, value, href, tone, big, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactItem'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:navy|red)$/]",
        "message": "<ContactItem> tone must be one of 'navy' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FaqItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|children|open|defaultOpen|onToggle|style|key|ref|className|style|children)$/]",
        "message": "<FaqItem> doesn't accept that prop. Declared props: question, children, open, defaultOpen, onToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GoogleRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:rating|count|style|key|ref|className|style|children)$/]",
        "message": "<GoogleRating> doesn't accept that prop. Declared props: rating, count, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|name|meta|initials|avatar|rating|style|key|ref|className|style|children)$/]",
        "message": "<ReviewCard> doesn't accept that prop. Declared props: quote, name, meta, initials, avatar, rating, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute[name.name='avatar'] > Literal[value!=/^(?:a|b|c)$/]",
        "message": "<ReviewCard> avatar must be one of 'a' | 'b' | 'c'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|icon|title|children|linkLabel|href|style|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: number, icon, title, children, linkLabel, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
